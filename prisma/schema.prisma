generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys        ApiKey[]
  contacts       Contact[]
  messages       WhatsAppMessage[]
  settings       Settings?
  subscription   Subscription?
  whatsAppSessions WhatsAppSession[]
  autoReplyLogs  AutoReplyLog[]
  templates      MessageTemplate[]
  scheduledMessages ScheduledMessage[]
  groups         Group[]
  chatbotRules   ChatbotRule[]
  products       Product[]
  webhookEvents    WebhookEvent[]
  passwordResetTokens PasswordResetToken[]
}

model ApiKey {
  id        String    @id @default(uuid())
  userId    String
  name      String
  key       String    @unique
  lastUsedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String
  createdAt DateTime @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups ContactGroup[]
}

model Group {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts ContactGroup[]
}

model ContactGroup {
  contactId String
  groupId   String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([contactId, groupId])
}

model WhatsAppMessage {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String   @default("main")
  to        String
  from      String
  messageId String   @unique
  body      String
  status    String   @default("pending")
  mediaUrl  String?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id              String   @id @default(uuid())
  userId          String   @unique
  webhookUrl      String?
  webhookSecret   String?
  autoReplyText   String?
  autoReplyActive Boolean  @default(false)
  watermarkText   String?
  watermarkActive Boolean  @default(false)

  msPerChar        Int    @default(100)
  readDelayMs      Int    @default(1500)
  typingEnabled    Boolean @default(true)
  broadcastEnabled Boolean @default(false)
  concurrency                Int    @default(1)
  adminNumbers               String[] @default([])
  safetyMode                 String   @default("normal")
  enterpriseCustomSettings   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  tier      String   @default("free")
  accountAge String   @default("newborn")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AutoReplyLog {
  id        String   @id @default(uuid())
  userId    String
  contact   String
  repliedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contact])
}

model WhatsAppSession {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String   @default("main")
  name       String   @default("Main Device")
  status     String   @default("disconnected")
  phone      String?
  qrCode     String?
  proxyUrl   String?
  dailyCount       Int      @default(0)
  monthlyCount     Int      @default(0)
  outboundCount    Int      @default(0)
  inboundCount     Int      @default(0)
  safetyViolations Int      @default(0)
  lastViolationAt  DateTime?
  isQuarantined    Boolean  @default(false)
  lastError        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
}

model MessageTemplate {
  id        String   @id @default(uuid())
  userId    String
  name      String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduledMessage {
  id          String   @id @default(uuid())
  userId      String
  recipients  Json     // [{ "to": "+628...", "name": "..." }]
  body        String
  scheduledAt DateTime
  status      String   @default("pending") // pending, processing, sent, failed, cancelled, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  isRecurring Boolean  @default(false)
  recurrence  String?  // "hourly" | "daily" | "weekly" | "monthly" | "custom"
  cronExpr    String?  // cron expression if custom
  interval    Int?     // every X hours/days/weeks (default 1)
  nextRunAt   DateTime? // next scheduled execution
  endDate     DateTime? // optional: stop at a certain date
  maxRepeats  Int?     // optional: max number of repetitions
  repeatCount Int      @default(0) // how many times already sent

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatbotRule {
  id        String   @id @default(uuid())
  userId    String
  name      String
  keywords  String[]
  response  String
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  price       Int?
  stock       Int?
  category    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model BaileysAuthCred {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  category  String   // creds | session | pre-key | sender-key | app-state-sync-key
  keyId     String?
  data      String   // serialized JSON with BufferJSON (Baileys)

  @@unique([userId, deviceId, category, keyId])
  @@index([userId, deviceId])
  @@map("baileys_auth_cred")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  userId      String
  eventType   String
  payload     Json
  processed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}