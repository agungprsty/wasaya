# Server
NODE_ENV=development
PORT=3001

# Security - WAJIB min 32 karakter
# Gunakan: openssl rand -base64 32
API_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# PostgreSQL — variable terpisah (bukan DATABASE_URL) untuk keamanan
PGHOST=localhost
PGPORT=5432
PGDATABASE=whatsapp_gateway
PGUSER=postgres
PGPASSWORD=postgres

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Session
SESSION_PATH=./data/.session
